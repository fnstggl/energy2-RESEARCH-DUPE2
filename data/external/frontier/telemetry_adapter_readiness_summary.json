  "coverage_matrix": [
    {
      "field": "observed_rps",
      "best_real_source": "vLLM rate(vllm:request_success_total[1m]), Ray Serve rate(ray_serve_num_ongoing_requests_total[1m]), Triton nv_inference_count rate",
      "status": "implemented",
      "tested": true,
      "confidence": "high"
    },
    {
      "field": "active_replicas",
      "best_real_source": "Kubernetes K8sPlacementSnapshot.running_gpu_pods or Ray Serve ray_serve_deployment_replica_count",
      "status": "implemented",
      "tested": true,
      "confidence": "high"
    },
    {
      "field": "queue_p99_ms",
      "best_real_source": "vLLM vllm:request_first_token_seconds (histogram p99) or Ray Serve ray_serve_request_latency_ms (p99)",
      "status": "partial",
      "tested": true,
      "confidence": "medium",
      "caveat": "queue percentile is end-to-end latency p99, not pure queue wait; vLLM has TTFT histogram; Triton averages only"
    },
    {
      "field": "queue_p95_ms",
      "best_real_source": "same family as queue_p99",
      "status": "partial",
      "tested": true,
      "confidence": "medium"
    },
    {
      "field": "queue_p50_ms",
      "best_real_source": "vLLM e2e_p50 OR Triton nv_inference_queue_duration_us / exec_count (average)",
      "status": "partial",
      "tested": true,
      "confidence": "medium"
    },
    {
      "field": "latency_p99_ms",
      "best_real_source": "vLLM e2e p99, Ray Serve request_latency p99",
      "status": "implemented",
      "tested": true,
      "confidence": "high",
      "caveat": "Triton default metrics expose averages only; histograms must be enabled in Triton config"
    },
    {
      "field": "latency_p95_ms",
      "best_real_source": "vLLM / Ray Serve histograms",
      "status": "implemented",
      "tested": true,
      "confidence": "high"
    },
    {
      "field": "latency_p50_ms",
      "best_real_source": "vLLM / Ray Serve histograms",
      "status": "implemented",
      "tested": true,
      "confidence": "high"
    },
    {
      "field": "timeout_pct",
      "best_real_source": "error_rate_pct (best-effort) OR pilot-derived from latency_p99 vs latency_sla_p99",
      "status": "partial",
      "tested": true,
      "confidence": "low",
      "caveat": "no mainstream runtime emits a SLA-aware timeout counter directly"
    },
    {
      "field": "sla_violation_pct",
      "best_real_source": "pilot-derived from latency_p99 vs latency_sla_p99",
      "status": "missing",
      "tested": false,
      "confidence": "low",
      "caveat": "requires pilot-side derivation against the workload's SLA policy"
    },
    {
      "field": "mean_utilization",
      "best_real_source": "DCGM DCGM_FI_DEV_GPU_UTIL (0-100, /100), or controller-supplied rho",
      "status": "implemented",
      "tested": true,
      "confidence": "high"
    },
    {
      "field": "scale_events_delta",
      "best_real_source": "Kubernetes Deployment.metadata.generation delta over window OR HPA events",
      "status": "partial",
      "tested": true,
      "confidence": "medium",
      "caveat": "K8s connector emits placement snapshot, not generation delta; requires a small follow-up export"
    },
    {
      "field": "churn_delta",
      "best_real_source": "derived from migration history or replica slope",
      "status": "partial",
      "tested": true,
      "confidence": "medium"
    },
    {
      "field": "gpu_hours_delta",
      "best_real_source": "derived = active_replicas * tick_duration_s / 3600",
      "status": "implemented",
      "tested": true,
      "confidence": "high"
    },
    {
      "field": "telemetry_confidence",
      "best_real_source": "Provenance.confidence (coverage-based: >70% high, >40% medium, else low)",
      "status": "implemented",
      "tested": true,
      "confidence": "high"
    },
    {
      "field": "prefix_cache_hit_rate (diagnostic)",
      "best_real_source": "vLLM vllm:gpu_prefix_cache_hit_rate",
      "status": "implemented",
      "tested": true,
      "confidence": "high",
      "caveat": "vLLM-only; Triton / Ray Serve do not surface this"
    },
    {
      "field": "model_residency / cold_start (diagnostic)",
      "best_real_source": "aurelius/residency/ingest.py adapt_vllm + pilot per-request CSV per PILOT_TELEMETRY_CONTRACT.md",
      "status": "partial",
      "tested": true,
      "confidence": "low",
      "caveat": "vLLM cannot emit per-request load timestamps; pilot must instrument the model-loader hook"
