# Aurelius environment variables
# Copy this file to .env and fill in your values.
# Never commit the real .env to version control.

# ---------------------------------------------------------------------------
# Grid data API keys
# ---------------------------------------------------------------------------

# EIA (U.S. Energy Information Administration) Open Data API v2
# Register free at: https://www.eia.gov/opendata/
EIA_API_KEY=your_eia_api_key_here

# ENTSO-E Transparency Platform (European electricity prices)
# Register at: https://transparency.entsoe.eu/
ENTSOE_API_KEY=your_entsoe_security_token_here

# ElectricityMaps carbon intensity API v3
# Register at: https://api.electricitymap.org
ELECTRICITYMAPS_API_KEY=your_electricitymaps_api_key_here

# ---------------------------------------------------------------------------
# Database (Supabase / Postgres)
# ---------------------------------------------------------------------------

# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=your_supabase_url_here

# Supabase anonymous public key
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Standard Postgres connection string (alternative to Supabase)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
