# Aurelius environment variables
# Copy this file to .env and fill in your values.
# Never commit the real .env to version control.

# ---------------------------------------------------------------------------
# Wholesale electricity price API keys
# ---------------------------------------------------------------------------

# CAISO OASIS (California ISO) – NO KEY REQUIRED
# Public API: https://oasis.caiso.com/oasisapi/SingleZip
# Covers us-west (NP15 trading hub, day-ahead LMP)
# (no env var needed)

# PJM Data Miner API 2 – Western Hub day-ahead LMP (us-east)
# Register free at: https://developer.pjm.com/
PJM_API_KEY=your_pjm_subscription_key_here

# ENTSO-E Transparency Platform (European electricity prices)
# Covers eu-west, eu-central, eu-north (day-ahead prices)
# Register at: https://transparency.entsoe.eu/
ENTSOE_API_KEY=your_entsoe_security_token_here

# EIA Open Data API (DEPRECATED for price use)
# EIA API v2 provides demand/load data, NOT wholesale electricity prices.
# Kept here for reference; EIAPriceProvider raises UnsupportedMarketPriceError.
# EIA_API_KEY=your_eia_api_key_here

# ---------------------------------------------------------------------------
# Carbon intensity API keys
# ---------------------------------------------------------------------------

# ElectricityMaps carbon intensity API v3
# Register at: https://api.electricitymap.org
# Aggregator/fallback for CARBON only. EM does NOT provide US wholesale prices
# or nodal LMP; use the direct ISO/TSO providers for prices. Free tier ~30
# req/min and ~90-day history; deeper carbon history requires a paid plan.
ELECTRICITYMAPS_API_KEY=your_electricitymaps_api_key_here
# Set to true to use the EM sandbox/demo endpoint. ALL returned data is then
# flagged is_sandbox=true and is REJECTED from any benchmark/savings claim.
# Sandbox = connector/schema tests only; never for economic claims.
ELECTRICITYMAPS_SANDBOX=false

# WattTime marginal emissions (MOER) API v3
# Register free at: https://www.watttime.org/api-documentation/
# Covers us-west (CAISO_NP15), us-east (PJM), us-south (ERCOT), us-north (MISO)
# Note: WattTime returns marginal emissions (MOER), not average carbon intensity.
WATTTIME_USERNAME=your_watttime_username_here
WATTTIME_PASSWORD=your_watttime_password_here

# ---------------------------------------------------------------------------
# Database (Supabase / Postgres)
# ---------------------------------------------------------------------------

# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=your_supabase_url_here

# Supabase anonymous public key
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Standard Postgres connection string (primary persistence layer)
# Aurelius uses SQLAlchemy with Postgres (production) or SQLite (dev/test).
# When set, the TimeSeriesStore persists price data, carbon intensity,
# and benchmark results. When not set, Aurelius falls back to CSV/JSONL files.
#
# Postgres (production / docker-compose):
# DATABASE_URL=postgresql://aurelius:aurelius@postgres:5432/aurelius
#
# SQLite (single-node dev / pilot without Postgres):
# DATABASE_URL=sqlite:///./aurelius.db
#
# Test (in-memory, destroyed on exit):
# DATABASE_URL=sqlite:///:memory:
DATABASE_URL=

# ---------------------------------------------------------------------------
# Application auth / runtime (Phase 3+)
# ---------------------------------------------------------------------------

# Shared API key for Aurelius REST API authentication
# Generate with: openssl rand -hex 32
AURELIUS_API_KEY=changeme_generate_a_real_secret

# Cache / rate limiting
REDIS_URL=redis://localhost:6379/0

# ML artifact storage path (local)
ML_ARTIFACTS_DIR=./ml_artifacts

# Post-execution records JSONL path
POST_EXECUTION_RECORDS_PATH=./data/post_execution_records.jsonl

# ---------------------------------------------------------------------------
# GPU Telemetry / DCGM / Prometheus (Tier 3 control-level optimization)
# ---------------------------------------------------------------------------
# DCGM does NOT require a public external API key.
# For PRODUCTION: the customer operates NVIDIA GPUs with DCGM + dcgm-exporter,
# and Prometheus scrapes dcgm-exporter. Aurelius connects as a Prometheus client.
# For FIXTURE/TESTING: no cluster needed — use DCGMProvider.from_prom_fixture()
# or DCGMProvider.generate_fixture().

# Base URL of the customer's Prometheus server
# PROMETHEUS_URL=http://prometheus.internal:9090

# Direct dcgm-exporter /metrics URL (alternative to Prometheus query)
# DCGM_EXPORTER_URL=http://dcgm-exporter.internal:9400

# Prometheus authentication (if protected)
# PROMETHEUS_BEARER_TOKEN=your_bearer_token_here
# PROMETHEUS_USERNAME=your_username_here
# PROMETHEUS_PASSWORD=your_password_here

# Set to "false" to disable TLS certificate verification (dev/self-signed only)
# PROMETHEUS_TLS_VERIFY=true
