# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Environment variables
.env

# Pytest
.pytest_cache/
.coverage
htmlcov/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Runtime lock files
*.lock

# Public-trace raw downloads + large normalized traces (downloaded, not
# committed; see docs/PUBLIC_TRACE_BACKTESTS.md). The small backtest summary
# JSON under processed/ IS committed.
data/external/burstgpt/raw/*.csv
data/external/burstgpt/processed/burstgpt_normalized.json
data/external/azure_llm/raw/*.csv
data/external/azure_llm/processed/azure_llm_normalized.json
# Azure LLM 2024 week-long raw files (~0.7-1.1 GB each; downloaded, not committed).
# The small processed summary JSONs ARE committed.
data/external/azure_llm_2024/raw/*.csv
!data/external/azure_llm_2024/raw/.gitkeep
data/external/alibaba_gpu/raw/*.csv
data/external/alibaba_gpu/processed/alibaba_gpu_normalized.json
data/external/philly/raw/*
!data/external/philly/raw/.gitkeep
# MIT Supercloud raw archives (~1 TB compressed; downloaded from
# https://dcc.mit.edu/data, NOT committed). Small processed summary
# JSON + tiny synthetic fixtures ARE committed.
data/external/mit_supercloud/raw/*
!data/external/mit_supercloud/raw/.gitkeep
# The small bounded-download manifest IS small enough to commit so
# reviewers can audit which S3 files were fetched. The large raw
# downloads remain excluded by the line above.
!data/external/mit_supercloud/raw/bounded_download_manifest.json
data/external/mit_supercloud/processed/mit_supercloud_normalized.json
data/external/mit_supercloud/processed/scheduler-log.csv
data/external/mit_supercloud/processed/labelled_jobids.csv
data/external/mit_supercloud/processed/tres-mapping.txt
data/external/mit_supercloud/processed/node-data.csv
data/external/mit_supercloud/processed/gpu/
data/external/mit_supercloud/processed/cpu/
data/external/philly/processed/philly_normalized.json
data/external/alibaba_genai/raw/*
!data/external/alibaba_genai/raw/.gitkeep
data/external/alibaba_genai/processed/alibaba_genai_normalized.json
# ShareGPT eval-conversation-shape head sample (bounded HTTP-Range download;
# raw JSON head is downloaded, NOT committed). The bounded-download manifest
# and the small processed summary ARE committed.
data/external/sharegpt_aiperf/raw/*
!data/external/sharegpt_aiperf/raw/.gitkeep
!data/external/sharegpt_aiperf/raw/bounded_download_manifest.json
# LMSYS Chatbot Arena (gated). Raw parquet + manifest are downloaded only
# when HF_TOKEN is supplied; not committed. The processed summary IS committed
# (records the schema fields + gating status, never the raw parquet).
data/external/lmsys_chatbot_arena/raw/*
!data/external/lmsys_chatbot_arena/raw/.gitkeep
!data/external/lmsys_chatbot_arena/raw/bounded_download_manifest.json

# Hugging Face dataset corpus — raw bounded downloads (gitignored). The small
# processed sample.jsonl + summary.json IS committed. See
# docs/HF_DATASET_REGISTRY.md for the federated corpus design.
data/external/hf/*/raw/*
data/external/hf/*/*/raw/*
!data/external/hf/.gitkeep
